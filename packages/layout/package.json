{
  "name": "@antdv-next1/pro-layout",
  "type": "module",
  "version": "1.0.7",
  "description": "@antdv-next1/pro-layout",
  "sideEffects": [
    "./dist/pro-layout.esm.js",
    "./dist/pro-layout.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./dist/pro-layout.esm.js": "./dist/pro-layout.esm.js",
    "./dist/pro-layout.js": "./dist/pro-layout.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "dist/pro-layout.js",
  "jsdelivr": "dist/pro-layout.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "run-s build:esm build:vite:parallel",
    "build:esm": "tsdown --config-loader unrun",
    "build:vite:parallel": "run-p build:umd build:full-esm",
    "build:full-esm": "vite build --config ./vite.esm.config.ts",
    "build:umd": "vite build",
    "build:token-meta": "tsx ./scripts/token/generate-token-meta.ts",
    "build:token-statistic": "cross-env NODE_ENV=production CSSINJS_STATISTIC=1 tsx ./scripts/token/collect-token-statistic.ts",
    "build:token": "run-p build:token-meta",
    "prepublish": "pnpm build"
  },
  "browserslist": [
    "last 2 versions",
    "Firefox ESR",
    "> 1%",
    "ie >= 11"
  ],
  "peerDependencies": {
    "antdv-next": ">=1.1.6",
    "vue": ">=3.5.30"
  },
  "dependencies": {
    "@antdv-next1/pro-listy": "1.0.1",
    "@antdv-next1/pro-provider": "1.0.1",
    "@antdv-next1/pro-utils": "1.0.6",
    "@antdv-next1/route-utils": "1.0.2",
    "swrv": "^1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "authors": [
    "Song Chao <archiesongqd@gmail.com> (https://github.com/asuradaSong)"
  ]
}
