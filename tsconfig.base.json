{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@antdv-next1/pro-utils": ["./packages/utils/src"],
      "@antdv-next1/pro-layout": ["./packages/layout/src"],
      "@antdv-next1/pro-provider": ["./packages/provider/src"],
      "@antdv-next1/pro-listy": ["./packages/listy/src"],
      "@antdv-next1/pro-card": ["./packages/card/src"],
      "@antdv-next1/pro-field": ["./packages/field/src"],
      "@antdv-next1/pro-form": ["./packages/form/src"],
      "@antdv-next1/pro-table": ["./packages/table/src"]
    },
    /* Linting */
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noUncheckedSideEffectImports": true
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "**/.pnpm/**"
  ]
}
